{
  "manifest_version": 3,
  "name": "Wazzzup — Bulk WhatsApp Sender",
  "version": "1.1.0",
  "description": "Send personalized messages to a list of phone numbers via WhatsApp Web",
  "permissions": ["storage", "activeTab", "scripting", "tabs"],
  "host_permissions": ["https://web.whatsapp.com/*"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://web.whatsapp.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "48": "icon48.png",
    "128": "icon128.png"
  }
}
