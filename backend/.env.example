# LeadGen Automation - Environment Variables
# Copy this file to .env and fill in your values

# ============ App Settings ============
APP_NAME=LeadGen Automation
DEBUG=false

# ============ Database ============
# PostgreSQL (recommended for production)
DATABASE_URL=postgresql+asyncpg://leadgen:leadgen_secret@localhost:5432/leadgen

# SQLite (for development/testing)
# DATABASE_URL=sqlite+aiosqlite:///./leadgen.db

# ============ OpenAI ============
# Required for AI enrichment features
OPENAI_API_KEY=sk-your-openai-api-key-here
DEFAULT_OPENAI_MODEL=gpt-4o-mini

# ============ Processing ============
BATCH_SIZE=25
MAX_CONCURRENT_REQUESTS=15

# ============ Integrations ============
# Instantly.ai API (optional)
INSTANTLY_API_KEY=

# ============ CORS ============
# Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:5174

# ============ Slack Integration ============
# Bot Token for Slack notifications (chat:write scope required)
SLACK_BOT_TOKEN=xoxb-your-slack-bot-token-here

# ============ Google Integration (Sheets + Drive) ============
# For reply logging to Google Sheets and file uploads to Google Drive
# Option 1: JSON string of service account credentials (like Ruby's GOOGLE_KEY)
# GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
# Option 2: Path to service account JSON file
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

# Optional: Shared Drive ID for file uploads
# If not set, files are uploaded to the service account's My Drive
# SHARED_DRIVE_ID=0AxxxxxxxxxxxxxxxxA

# ============ Infatica Residential Proxy ============
# For Telegram account geo-targeted proxies (SOCKS5)
INFATICA_PROXY_USERNAME=
INFATICA_PROXY_PASSWORD=

# Telegram Bots
TELEGRAM_BOT_TOKEN=
TELEGRAM_SALLY_BOT_TOKEN=
