# ============================================================
# GTM MCP — Environment Variables
# ============================================================
# Copy to .env and fill in real values.
# MCP is INDEPENDENT from the main backend — own DB, own keys.
# API keys here are FALLBACK defaults for users who don't set
# their own keys via the Setup page.
# ============================================================

# ── Database (MCP's own PostgreSQL — NOT shared with main app) ──
DATABASE_URL=postgresql+asyncpg://mcp:mcp_secret@mcp-postgres:5432/mcp_leadgen

# ── Redis ───────────────────────────────────────────────────
REDIS_URL=redis://mcp-redis:6379/0

# ── AI Keys (fallback — users can set their own via Setup page) ──
OPENAI_API_KEY=sk-...
GEMINI_API_KEY=
ANTHROPIC_API_KEY=

# ── Apollo (fallback) ──────────────────────────────────────
APOLLO_API_KEY=

# ── SmartLead (fallback) ───────────────────────────────────
SMARTLEAD_API_KEY=

# ── FindyMail (fallback — COSTS MONEY, be careful) ────────
FINDYMAIL_API_KEY=

# ── Apify Residential Proxy (for website scraping) ─────────
APIFY_PROXY_PASSWORD=

# ── Encryption (auto-generated if not set) ─────────────────
ENCRYPTION_KEY=

# ── Telegram Bot ───────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
