{
  "id": "19_reply_intelligence",
  "description": "User 1 (pn@getsally.io): Deep reply intelligence — warm leads, follow-ups needed, reply sentiment, CRM deep links. Tests replies_summary, replies_list, replies_followups, replies_deep_link.",
  "user_email": "pn@getsally.io",
  "project_name": "EasyStaff-Global",
  "depends_on": "16_campaign_lifecycle",

  "preconditions": {
    "user_authenticated": true,
    "project_selected": "EasyStaff-Global",
    "campaign_active": true,
    "reply_monitoring_on": true
  },

  "steps": [
    {
      "step": 1,
      "phase": "reply_summary",
      "description": "User asks for reply overview. MCP should show counts by category.",
      "user_prompt": "How are my campaigns doing? Any replies?",
      "user_prompt_variants": [
        "Show me the reply summary",
        "What's the reply situation?",
        "Any warm replies?"
      ],
      "expected_tool_calls": ["replies_summary"],
      "expected_behavior": {
        "total_replies_shown": true,
        "categories_shown": true,
        "warm_count_shown": true,
        "crm_link_provided": true,
        "response_must_contain_any": ["replies", "warm", "interested", "total"],
        "response_must_contain": ["_links"]
      }
    },
    {
      "step": 2,
      "phase": "warm_leads_detail",
      "description": "User wants to see warm/interested leads specifically.",
      "user_prompt": "Show me the warm leads",
      "user_prompt_variants": [
        "Which leads are interested?",
        "List the warm replies",
        "Who's showing interest?"
      ],
      "expected_tool_calls": ["replies_list"],
      "expected_behavior": {
        "filtered_by_category": "interested",
        "leads_shown_with_details": true,
        "each_lead_has_email": true,
        "each_lead_has_company": true,
        "each_lead_has_message_preview": true,
        "crm_link_for_warm": true,
        "response_must_contain_any": ["lead", "reply", "interested", "company"]
      }
    },
    {
      "step": 3,
      "phase": "followups_needed",
      "description": "User asks which leads need follow-ups.",
      "user_prompt": "Which leads need follow-ups?",
      "user_prompt_variants": [
        "Who needs a follow-up?",
        "Any leads I should follow up with?",
        "Show me leads that need attention"
      ],
      "expected_tool_calls": ["replies_followups"],
      "expected_behavior": {
        "followup_list_shown": true,
        "crm_link_for_followups": true,
        "response_must_contain_any": ["follow", "reply", "need"]
      }
    },
    {
      "step": 4,
      "phase": "deep_link_to_crm",
      "description": "User wants to see a specific lead in CRM.",
      "user_prompt": "Open this lead in CRM",
      "user_prompt_variants": [
        "Show me this contact in the CRM",
        "Take me to the CRM for this lead",
        "Open in CRM"
      ],
      "expected_tool_calls": ["replies_deep_link"],
      "expected_behavior": {
        "crm_url_returned": true,
        "url_has_project_param": true,
        "url_has_lead_param": true,
        "response_must_contain": ["crm", "http"]
      },
      "critical_requirement": "CRM deep link MUST include project param so user sees correct context."
    },
    {
      "step": 5,
      "phase": "meeting_requests",
      "description": "User asks specifically about meeting requests.",
      "user_prompt": "Any meeting requests?",
      "user_prompt_variants": [
        "Did anyone ask for a meeting?",
        "Show me meeting request replies",
        "Any meetings booked?"
      ],
      "expected_tool_calls": ["replies_list"],
      "expected_behavior": {
        "filtered_by_category": "meeting_request",
        "response_must_contain_any": ["meeting", "0", "no meeting", "request"]
      }
    }
  ],

  "final_verification": {
    "db_checks": [
      "replies_summary returns correct counts for each category",
      "replies_list filters work (interested, meeting_request, etc.)",
      "Deep links include project= parameter",
      "All reply data comes from MCP's own database (NOT main backend)"
    ]
  }
}
