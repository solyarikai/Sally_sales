{
  "id": "00_qwe_test_framework_validation",
  "description": "Test framework validation \u2014 full user journey with qwe@qwe.qwe. Proves real conversation testing works: GPT decides tools, MCP executes via SSE, results scored.",
  "user_email": "qwe@qwe.qwe",
  "user_password": "qweqweqwe",
  "project_name": "QWE-TestProject",
  "steps": [
    {
      "step": 1,
      "phase": "context_check",
      "user_prompt": "What projects do I have? Show me my current state.",
      "user_prompt_variants": [
        "Show my projects",
        "What is my current setup?"
      ],
      "expected_tool_calls": [
        "get_context"
      ],
      "expected_behavior": {
        "response_must_contain_any": [
          "project",
          "no project",
          "QWE",
          "ready"
        ]
      }
    },
    {
      "step": 2,
      "phase": "create_project",
      "user_prompt": "Create a project called QWE-TestProject. My website is easystaff.io",
      "user_prompt_variants": [
        "Set up project QWE-TestProject, website easystaff.io",
        "New project: QWE-TestProject, site is easystaff.io"
      ],
      "expected_tool_calls": [
        "create_project"
      ],
      "expected_behavior": {
        "response_must_contain_any": [
          "created",
          "project",
          "QWE"
        ]
      }
    },
    {
      "step": 3,
      "phase": "check_integrations",
      "user_prompt": "What integrations do I have connected?",
      "user_prompt_variants": [
        "Show my API keys",
        "Which services are connected?"
      ],
      "expected_tool_calls": [
        "check_integrations"
      ],
      "expected_behavior": {
        "response_must_contain_any": [
          "integration",
          "connected",
          "SmartLead",
          "Apollo",
          "not connected"
        ]
      }
    },
    {
      "step": 4,
      "phase": "list_sources",
      "user_prompt": "What data sources are available for gathering?",
      "user_prompt_variants": [
        "How can I gather companies?",
        "What sources can I use?"
      ],
      "expected_tool_calls": [
        "tam_list_sources"
      ],
      "expected_behavior": {
        "response_must_contain_any": [
          "Apollo",
          "CSV",
          "Google",
          "source"
        ]
      }
    },
    {
      "step": 5,
      "phase": "list_email_accounts",
      "user_prompt": "Show me available email accounts for campaigns",
      "user_prompt_variants": [
        "What email accounts can I use?",
        "List sending accounts"
      ],
      "expected_tool_calls": [
        "list_email_accounts"
      ],
      "expected_behavior": {
        "response_must_contain_any": [
          "email",
          "account",
          "available",
          "no accounts"
        ]
      }
    },
    {
      "step": 6,
      "phase": "reply_summary",
      "user_prompt": "Do I have any replies? Show me the reply summary for QWE-TestProject",
      "user_prompt_variants": [
        "Any warm replies?",
        "Reply status for my project?"
      ],
      "expected_tool_calls": [
        "replies_summary"
      ],
      "expected_behavior": {
        "response_must_contain_any": [
          "reply",
          "replies",
          "warm",
          "total",
          "0",
          "no replies"
        ]
      }
    },
    {
      "step": 7,
      "phase": "estimate_cost",
      "user_prompt": "How much would it cost to find 50 IT consulting companies in Miami via Apollo?",
      "user_prompt_variants": [
        "Estimate Apollo credits for 50 companies",
        "What is the cost estimate?"
      ],
      "expected_tool_calls": [
        "estimate_cost"
      ],
      "expected_behavior": {
        "response_must_contain_any": [
          "credit",
          "cost",
          "estimate",
          "page"
        ]
      }
    }
  ],
  "final_verification": {
    "ui_screenshots": [
      {
        "page": "/pipeline",
        "checks": [
          "Pipeline page loads"
        ]
      },
      {
        "page": "/projects",
        "checks": [
          "QWE-TestProject visible"
        ]
      },
      {
        "page": "/setup",
        "checks": [
          "Setup page loads"
        ]
      }
    ]
  }
}