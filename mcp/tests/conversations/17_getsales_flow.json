{
  "id": "17_getsales_flow",
  "description": "User 1 (pn@getsally.io): Destination clarification when both SmartLead + GetSales keys present. User chooses GetSales for LinkedIn outreach. Tests gs_* tools end-to-end.",
  "user_email": "pn@getsally.io",
  "project_name": "EasyStaff-Global",
  "depends_on": "16_campaign_lifecycle",

  "preconditions": {
    "user_authenticated": true,
    "project_selected": "EasyStaff-Global",
    "smartlead_key_configured": true,
    "getsales_key_configured": true,
    "pipeline_has_targets": true
  },

  "steps": [
    {
      "step": 1,
      "phase": "destination_clarification",
      "description": "User says 'create campaign for these targets'. MCP should detect BOTH keys and ask which destination.",
      "user_prompt": "Create a campaign for the IT consulting targets",
      "user_prompt_variants": [
        "Launch outreach for the targets we found",
        "I want to start reaching out to these companies",
        "Create campaign for the pipeline targets"
      ],
      "expected_behavior": {
        "mcp_detects_both_keys": true,
        "mcp_asks_destination": true,
        "response_must_contain_any": ["SmartLead", "GetSales", "destination", "which platform"],
        "mcp_does_NOT_auto_choose": true
      },
      "critical_requirement": "When BOTH SmartLead and GetSales keys are configured, MCP MUST ask which destination. Never auto-choose."
    },
    {
      "step": 2,
      "phase": "choose_getsales",
      "description": "User chooses GetSales for LinkedIn outreach.",
      "user_prompt": "Use GetSales for LinkedIn outreach",
      "user_prompt_variants": [
        "Go with GetSales",
        "LinkedIn outreach via GetSales",
        "GetSales please"
      ],
      "expected_behavior": {
        "destination_set_to_getsales": true
      }
    },
    {
      "step": 3,
      "phase": "sender_selection",
      "description": "MCP asks which LinkedIn sender profile to use.",
      "expected_tool_calls": ["gs_list_sender_profiles"],
      "expected_behavior": {
        "shows_sender_profiles": true,
        "response_must_contain_any": ["sender", "profile", "LinkedIn", "account"]
      }
    },
    {
      "step": 4,
      "phase": "flow_generation",
      "description": "Generate GetSales LinkedIn automation flow.",
      "user_prompt": "Generate the LinkedIn flow",
      "expected_tool_calls": ["gs_generate_flow"],
      "expected_behavior": {
        "flow_generated": true,
        "flow_has_steps": true,
        "response_must_contain": ["flow", "LinkedIn", "step"]
      }
    },
    {
      "step": 5,
      "phase": "flow_approval",
      "user_prompt": "Looks good, approve the flow",
      "expected_tool_calls": ["gs_approve_flow"],
      "expected_behavior": {
        "flow_approved": true
      }
    },
    {
      "step": 6,
      "phase": "push_to_getsales",
      "user_prompt": "Push to GetSales",
      "expected_tool_calls": ["gs_push_to_getsales"],
      "expected_behavior": {
        "flow_pushed": true,
        "status": "DRAFT",
        "response_must_contain": ["GetSales", "DRAFT", "pushed"]
      }
    }
  ],

  "final_verification": {
    "db_checks": [
      "Campaign record with platform='getsales'",
      "Flow ID stored in campaign config"
    ]
  }
}
