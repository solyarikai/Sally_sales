      "critical_requirement": "Uses optimized filters + tuned prompt. More pages from Apollo. Does NOT re-search already gathered companies."
    },
    {
      "step": 18,
      "phase": "5.1_sequence_generation",
      "user_prompt": "Generate the email sequence",
      "expected_tool_calls": ["smartlead_generate_sequence"],
      "expected_behavior": {
        "response_must_contain_any": ["sequence", "email", "subject", "step"]
      }
    },
    {
      "step": 19,
      "phase": "5.2_approve_push",
      "user_prompt": "Looks good, push to SmartLead",
