{
  "id": "01_full_journey_easystaff",
  "description": "Complete user journey from ZERO \u2014 no account, no knowledge of the system. Covers: auth, setup, campaigns, blacklist, gathering 2 segments + 2 geos, sequence, campaign, reply intelligence",
  "user_email": "pn@getsally.io",
  "user_password": "qweqweqwe",
  "steps": [
    {
      "step": 1,
      "phase": "first_contact",
      "user_prompt": "Hey, I want to launch outreach for my company",
      "user_prompt_variants": [
        "Hi, I need to start gathering leads for outreach",
        "I want to set up lead generation campaigns",
        "Help me find companies to reach out to"
      ],
      "expected_mcp_behavior": {
        "must_ask_for_token": true,
        "must_provide_signup_link": true,
        "link_expected": "http://46.62.210.24:3000/setup",
        "message_must_contain": [
          "sign up",
          "token",
          "setup"
        ],
        "must_not_proceed_without_auth": true
      }
    },
    {
      "step": 2,
      "phase": "auth",
      "description": "User signs up via UI, gets token, provides it to MCP",
      "user_prompt": "Here's my token: mcp_xxx...",
      "expected_mcp_behavior": {
        "tool_calls": [
          "login"
        ],
        "verifies_token": true,
        "greets_user_by_name": true,
        "asks_about_company": true,
        "message_must_contain": [
          "welcome",
          "website",
          "what do you"
        ]
      }
    },
    {
      "step": 3,
      "phase": "company_context",
      "user_prompt": "My website is https://easystaff.io/. I'm Eleonora, BDM at EasyStaff",
      "user_prompt_variants": [
        "Check out easystaff.io \u2014 that's us. I'm Eleonora",
        "Our company is EasyStaff, website easystaff.io. My name is Eleonora, I'm BDM"
      ],
      "expected_mcp_behavior": {
        "tool_calls": [
          "create_project"
        ],
        "website_scraped": true,
        "offer_extracted": true,
        "must_provide_link": "http://46.62.210.24:3000/projects",
        "message_must_contain": [
          "project",
          "created",
          "scraped"
        ]
      }
    },
    {
      "step": 4,
      "phase": "api_keys",
      "description": "MCP checks integrations \u2014 asks for missing keys",
      "user_prompt": "What API keys do I need to connect?",
      "user_prompt_variants": ["Check my integrations", "Which services are connected?", "Show my API connections"],
      "expected_mcp_behavior": {
        "tool_calls": [
          "check_integrations"
        ],
        "must_ask_for_keys": [
          "smartlead",
          "apollo",
          "openai"
        ],
        "must_provide_link": "http://46.62.210.24:3000/setup",
        "message_must_contain": [
          "API key",
          "SmartLead",
          "Apollo",
          "connect"
        ]
      }
    },
    {
      "step": 5,
      "phase": "existing_campaigns",
      "description": "After SmartLead connected, MCP asks about existing campaigns",
      "user_prompt": "All campaigns including 'petr' in their names are my campaigns",
      "user_prompt_variants": [
        "My campaigns have 'petr' in the name",
        "Look for SmartLead campaigns with petr in the name \u2014 those are mine",
        "Campaigns matching petr are for this project"
      ],
      "expected_mcp_behavior": {
        "tool_calls": [
          "list_smartlead_campaigns",
          "import_smartlead_campaigns"
        ],
        "campaigns_found_min": 5,
        "contacts_imported_as_blacklist": true,
        "background_reply_analysis_started": true,
        "must_provide_link": "http://46.62.210.24:3000/pipeline",
        "message_must_contain": [
          "campaigns",
          "found",
          "blacklist",
          "contacts"
        ]
      }
    },
    {
      "step": 6,
      "phase": "gathering_multi_segment_multi_geo",
      "user_prompt": "Find IT consulting companies in Miami and video production companies in London",
      "user_prompt_variants": [
        "I need IT consulting firms in Miami, and also video production companies in London UK",
        "Two segments: 1) IT consulting, Miami 2) video production, London",
        "Gather leads \u2014 IT consulting Miami + video production London"
      ],
      "expected_mcp_behavior": {
        "tool_calls": [
          "parse_gathering_intent"
        ],
        "segments_parsed": 2,
        "segment_1": {
          "label_contains": "IT_CONSULTING",
          "geo": "Miami"
        },
        "segment_2": {
          "label_contains": "VIDEO_PRODUCTION",
          "geo": "London"
        },
        "competitor_exclusions_present": true,
        "message_must_contain": [
          "2 segment",
          "IT",
          "video",
          "Miami",
          "London"
        ]
      }
    },
    {
      "step": 7,
      "phase": "gathering_execution",
      "description": "MCP runs tam_gather TWICE (different segments + geos)",
      "user_prompt": "Go ahead and gather companies for both segments",
      "user_prompt_variants": ["Start gathering for IT consulting and video production", "Launch the pipeline for both segments"],
      "expected_mcp_behavior": {
        "tool_calls": [
          "tam_gather",
          "tam_gather"
        ],
        "pipeline_runs_created": 2,
        "each_run_has_companies": true,
        "must_provide_links": [
          "http://46.62.210.24:3000/pipeline/"
        ],
        "message_must_contain": [
          "companies",
          "gathered",
          "pipeline"
        ]
      }
    },
    {
      "step": 8,
      "phase": "pipeline_processing",
      "description": "Blacklist \u2192 CP1 \u2192 pre-filter \u2192 scrape \u2192 analyze for both runs",
      "user_prompt": "Run the full pipeline — blacklist, scrape, and analyze all gathered companies",
      "user_prompt_variants": ["Process the pipeline", "Run blacklist check and analysis"],
      "expected_mcp_behavior": {
        "tool_calls": [
          "tam_blacklist_check",
          "tam_blacklist_check",
          "tam_approve_checkpoint",
          "tam_approve_checkpoint",
          "tam_pre_filter",
          "tam_pre_filter",
          "tam_scrape",
          "tam_scrape",
          "tam_analyze",
          "tam_analyze"
        ],
        "blacklist_cross_checks_against_imported_campaigns": true,
        "targets_found_min": 5,
        "segment_labels_match_user_query": true
      }
    },
    {
      "step": 9,
      "phase": "email_accounts",
      "description": "MCP MUST ask which email accounts to use \u2014 NEVER auto-pick",
      "expected_mcp_behavior": {
        "mcp_asks_user": true,
        "tool_calls": [
          "list_email_accounts"
        ],
        "shows_account_list": true,
        "message_must_contain": [
          "email account",
          "which"
        ],
        "waits_for_user_response": true
      },
      "user_prompt": "Use all email accounts from my petr campaigns that have Eleonora in the name",
      "user_prompt_variants": [
        "Use Eleonora's sending accounts from the petr campaigns",
        "Pick accounts with eleonora in the email from my existing campaigns",
        "Use the Eleonora accounts, the ones from petr campaigns"
      ],
      "expected_after_user_response": {
        "filters_accounts_by": "eleonora",
        "accounts_from_campaigns_matching": "petr",
        "accounts_selected_min": 3
      }
    },
    {
      "step": 10,
      "phase": "sequence_and_campaign",
      "description": "Generate sequence, push to SmartLead as DRAFT with user-selected accounts",
      "user_prompt": "Generate the outreach email sequence for my campaign",
      "user_prompt_variants": ["Create a 5-step email sequence for this project", "Build the email sequence based on our offer and targets"],
      "expected_mcp_behavior": {
        "tool_calls": [
          "smartlead_generate_sequence",
          "god_approve_sequence",
          "god_push_to_smartlead"
        ],
        "god_push_includes_email_account_ids": true,
        "campaign_status": "DRAFT",
        "campaign_never_activated": true,
        "contacts_auto_uploaded": true,
        "test_email_auto_sent": true,
        "sequence_has_personalization": [
          "{{first_name}}",
          "{{city}}"
        ],
        "sequence_references_easystaff_offer": true,
        "must_provide_links": [
          "smartlead.ai",
          "/campaigns"
        ],
        "message_must_contain": [
          "DRAFT",
          "campaign",
          "check your inbox",
          "approval"
        ]
      }
    },
    {
      "step": 11,
      "phase": "reply_intelligence",
      "user_prompt": "Which leads need follow-ups? And which replies are warm?",
      "user_prompt_variants": [
        "Show me warm replies and who needs a follow-up",
        "Any warm leads? Who should I reply to?",
        "What's the reply status? Who's interested?"
      ],
      "expected_mcp_behavior": {
        "tool_calls": [
          "replies_summary",
          "replies_followups"
        ],
        "replies_scoped_to_user_campaigns": true,
        "not_all_38k_replies": true,
        "must_provide_links": [
          "http://46.62.210.24:3000/crm"
        ],
        "crm_link_has_filter": true,
        "message_must_contain": [
          "warm",
          "follow-up",
          "interested"
        ]
      }
    },
    {
      "step": 12,
      "phase": "pending_campaigns_check",
      "description": "MCP should mention pending DRAFT campaigns",
      "user_prompt": "Do I have any pending campaigns? What's their status?",
      "user_prompt_variants": ["Show my draft campaigns", "Any campaigns waiting to launch?"],
      "expected_mcp_behavior": {
        "mentions_pending_campaigns": true,
        "asks_about_activation": true,
        "message_must_contain": [
          "campaign",
          "DRAFT",
          "ready",
          "launch"
        ],
        "link_to_smartlead": true
      }
    }
  ],
  "final_verification": {
    "ui_screenshots": [
      {
        "page": "/pipeline",
        "checks": [
          "2+ runs visible with segment badges",
          "project column shows EasyStaff-Global",
          "targets count clickable",
          "no duplicate rows"
        ]
      },
      {
        "page": "/pipeline/{run_id}?status=target",
        "checks": [
          "only target companies shown",
          "no duplicate domains",
          "SmartLead campaign link visible (purple badge)"
        ]
      },
      {
        "page": "/pipeline/{run_id}/prompts",
        "checks": [
          "at least 1 prompt entry with body",
          "targets count visible"
        ]
      },
      {
        "page": "/conversations",
        "checks": [
          "30+ messages",
          "both directions (\u2192 MCP and \u2190 Response)",
          "full tool call history from step 1 to step 12"
        ]
      },
      {
        "page": "/projects",
        "checks": [
          "EasyStaff-Global project with campaigns list",
          "pipeline runs linked"
        ]
      },
      {
        "page": "/crm?reply_category=interested",
        "checks": [
          "warm replies visible",
          "scoped to user's campaigns only"
        ]
      },
      {
        "page": "/setup",
        "checks": [
          "user logged in",
          "all 3 integrations connected (green dots)"
        ]
      }
    ],
    "scoring": {
      "correct_tools_called": "30%",
      "response_structure": "25%",
      "links_included": "15%",
      "segment_accuracy": "15%",
      "no_errors": "15%",
      "pass_threshold": "80%",
      "god_threshold": "95%"
    }
  },
  "project_name": "EasyStaff-Global"
}