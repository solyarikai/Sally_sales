    {
      "step": 14,
      "phase": "7.1_iteration_visible",
      "user_prompt": "Show the pipeline results",
      "expected_tool_calls": ["pipeline_status"],
      "expected_behavior": {
        "response_must_contain_any": ["iteration", "target", "filter"]
