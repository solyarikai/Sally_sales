      "critical_requirement": "Feedback accepted. Prompt adjusted. New iteration created. Same companies, different classification."
    },
    {
      "step": 16,
      "phase": "7.3_iteration2_results",
      "user_prompt": "How did the re-analysis go?",
      "expected_tool_calls": ["pipeline_status"],
      "expected_behavior": {
        "response_must_contain_any": ["iteration", "target", "improved"]
      },
      "critical_requirement": "Iteration 2 visible. Target count different from iteration 1. Better accuracy."
    },
    {
      "step": 17,
      "phase": "7.6_scale",
      "user_prompt": "Good, now find more companies with these filters",
      "user_prompt_variants": ["Gather more", "Scale up"],
