      "expected_behavior": {
        "response_must_contain_any": ["sign up", "token", "mcp_", "setup"],
        "response_must_NOT_contain": ["segments", "Apollo", "pipeline"]
      },
      "critical_requirement": "MCP must ONLY ask for token. No other info. No tools listed."
    },
    {
      "step": 2,
      "phase": "1.2_login",
      "user_prompt": "Here is my token: mcp_df8748d67f4d3734682a01c0ab9df1932df0308d4279ffeb5446a94863308110",
      "expected_tool_calls": ["login"],
      "expected_behavior": {
        "response_must_contain_any": ["apollo", "smartlead", "openai", "key", "setup"]
      }
    },
    {
      "step": 3,
      "phase": "1.4_keys_configured",
      "user_prompt": "I set up all the keys in the interface",
      "user_prompt_variants": ["Keys are configured now"],
      "expected_tool_calls": ["check_integrations"],
      "expected_behavior": {
        "response_must_contain_any": ["ready", "segment", "launch", "which"]
      },
      "critical_requirement": "MCP asks 'which segments?' — ONE question only"
    },
    {
      "step": 4,
      "phase": "1.5_segments_before_offer",
