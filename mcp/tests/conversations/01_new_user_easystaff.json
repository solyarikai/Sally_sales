    {
      "step": 10,
      "phase": "4.1_blacklist_check",
      "user_prompt": "What's the pipeline status?",
      "user_prompt_variants": ["How is gathering going?"],
      "expected_tool_calls": ["pipeline_status"],
      "expected_behavior": {
        "response_must_contain_any": ["blacklist", "checkpoint", "approve", "companies"]
