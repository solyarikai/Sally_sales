      "expected_behavior": {
        "response_must_contain_any": ["offer", "website", "what do you sell", "product"]
      },
      "critical_requirement": "MCP must ask for offer/website BEFORE parsing segments. ONE question."
    },
    {
      "step": 5,
      "phase": "2.1_provide_website",
      "user_prompt": "easystaff.io",
      "user_prompt_variants": ["Our website is easystaff.io"],
      "expected_tool_calls": ["create_project"],
      "expected_behavior": {
        "response_must_contain_any": ["project", "EasyStaff", "created"],
        "response_must_contain": "campaign"
      },
      "critical_requirement": "MCP creates project from website, asks about previous campaigns. ONE question."
    },
    {
      "step": 6,
      "phase": "2.2_previous_campaigns",
      "user_prompt": "Yes, campaigns with petr in the name were launched before",
      "user_prompt_variants": ["Campaigns including petr"],
