{
  "id": "01_default_smartlead_flow",
  "description": "DEFAULT FLOW: token > keys > segments > offer > project > campaigns > blacklist > exploration > pipeline > email accounts > campaign > test email > approve > launch > replies",
  "user_email": "pn@getsally.io",
  "user_password": "qweqweqwe",
  "project_name": "EasyStaff",
  "steps": [
    {
      "step": 1,
      "phase": "greeting_no_token",
      "user_prompt": "Hey, I want to launch some campaigns",
      "user_prompt_variants": [
        "Hi there",
        "Help me find leads"
      ],
      "expected_behavior": {
        "response_must_contain_any": [
          "sign up",
          "token",
          "mcp_",
          "setup"
        ]
      }
    },
    {
      "step": 2,
      "phase": "login",
      "user_prompt": "Here is my token: TOKEN_PLACEHOLDER",
      "expected_tool_calls": [
        "login",
        "check_integrations"
      ],
      "expected_behavior": {
        "response_must_contain_any": [
          "apollo",
          "smartlead",
          "openai",
          "apify",
          "key"
        ]
      }
    },
    {
      "step": 3,
      "phase": "keys_setup",
      "user_prompt": "I set up all the keys in the interface",
      "user_prompt_variants": [
        "Keys are configured now"
      ],
      "expected_tool_calls": [
        "check_integrations"
      ],
      "expected_behavior": {
        "response_must_contain_any": [
          "ready",
          "segment",
          "launch",
          "which"
        ]
      }
    },
    {
      "step": 4,
      "phase": "segments_request",
      "user_prompt": "Find IT consulting companies in Miami and video production agencies in London",
      "user_prompt_variants": [
        "Two segments: IT consulting Miami, video production London"
      ],
      "expected_behavior": {
        "response_must_contain_any": [
          "offer",
          "website",
          "what do you sell",
          "product"
        ]
      }
    },
    {
      "step": 5,
      "phase": "offer_from_website",
      "user_prompt": "easystaff.io",
      "user_prompt_variants": [
        "Our website is easystaff.io"
      ],
      "expected_tool_calls": [
        "create_project"
      ],
      "expected_behavior": {
        "response_must_contain_any": [
          "project",
          "created",
          "EasyStaff"
        ]
      }
    },
    {
      "step": 6,
      "phase": "previous_campaigns",
      "user_prompt": "Yes, campaigns with petr in the name were launched before",
      "user_prompt_variants": [
        "Campaigns including petr"
      ],
      "expected_tool_calls": [
        "import_smartlead_campaigns"
      ],
      "expected_behavior": {
        "response_must_contain_any": [
          "campaign",
          "blacklist",
          "contact",
          "loaded"
        ]
      }
    },
    {
      "step": 7,
      "phase": "filter_alignment",
      "user_prompt": "Go ahead, what are the filters?",
      "user_prompt_variants": [
        "Show me the Apollo filters"
      ],
      "expected_tool_calls": [
        "parse_gathering_intent"
      ],
      "expected_behavior": {
        "response_must_contain_any": [
          "filter",
          "IT consulting",
          "Miami",
          "video",
          "London"
        ]
      }
    },
    {
      "step": 8,
      "phase": "pipeline_launch",
      "user_prompt": "Looks good, launch the pipelines",
      "user_prompt_variants": [
        "Start gathering",
        "Launch it"
      ],
      "expected_tool_calls": [
        "tam_gather"
      ],
      "expected_behavior": {
        "response_must_contain_any": [
          "pipeline",
          "gathering",
          "companies",
          "launched"
        ]
      }
    },
    {
      "step": 9,
      "phase": "email_accounts",
      "user_prompt": "Use Eleonora accounts from the petr campaigns for both",
      "user_prompt_variants": [
        "Eleonora accounts from previous campaigns for both"
      ],
      "expected_tool_calls": [
        "list_email_accounts"
      ],
      "expected_behavior": {
        "response_must_contain_any": [
          "eleonora",
          "email",
          "account"
        ]
      }
    },
    {
      "step": 10,
      "phase": "pipeline_stats",
      "user_prompt": "How is the pipeline going?",
      "user_prompt_variants": [
        "Pipeline status?"
      ],
      "expected_tool_calls": [
        "pipeline_status"
      ],
      "expected_behavior": {
        "response_must_contain_any": [
          "target",
          "companies",
          "found",
          "pipeline"
        ]
      }
    },
    {
      "step": 11,
      "phase": "campaign_creation",
      "user_prompt": "Create the SmartLead campaigns",
      "user_prompt_variants": [
        "Push to SmartLead"
      ],
      "expected_tool_calls": [
        "smartlead_push_campaign"
      ],
      "expected_behavior": {
        "response_must_contain_any": [
          "DRAFT",
          "campaign",
          "SmartLead",
          "inbox"
        ]
      }
    },
    {
      "step": 12,
      "phase": "approve_launch",
      "user_prompt": "Checked inbox, looks good. Launch the campaigns.",
      "user_prompt_variants": [
        "Approved, activate"
      ],
      "expected_tool_calls": [
        "activate_campaign"
      ],
      "expected_behavior": {
        "response_must_contain_any": [
          "activated",
          "launched",
          "monitoring"
        ]
      }
    },
    {
      "step": 13,
      "phase": "reply_intelligence",
      "user_prompt": "Any warm replies? Which leads need follow-ups?",
      "user_prompt_variants": [
        "Show warm replies and follow-ups"
      ],
      "expected_tool_calls": [
        "replies_summary"
      ],
      "expected_behavior": {
        "response_must_contain_any": [
          "warm",
          "reply",
          "follow",
          "lead"
        ]
      }
    },
    {
      "step": 14,
      "phase": "crm_link",
      "user_prompt": "Show me contacts in CRM",
      "expected_tool_calls": [
        "replies_deep_link"
      ],
      "expected_behavior": {
        "response_must_contain_any": [
          "crm",
          "http",
          "contacts"
        ]
      }
    }
  ]
}