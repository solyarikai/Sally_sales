  "user_email": "test1@getsally.io",
  "user_password": "testtest123",
  "user_token": "mcp_df8748d67f4d3734682a01c0ab9df1932df0308d4279ffeb5446a94863308110",
  "project_name": "EasyStaff",
  "steps": [
    {
      "step": 1,
      "phase": "1.1_greeting_no_token",
      "user_prompt": "Hey, I want to launch some campaigns",
