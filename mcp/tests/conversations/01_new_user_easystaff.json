      "expected_behavior": {
        "response_must_contain_any": ["filter", "keyword", "available", "companies", "credit"],
        "response_must_NOT_contain": ["launched", "gathering started"]
      },
      "critical_requirement": "MCP shows filter PREVIEW with Apollo total + cost estimate. Does NOT start gathering yet. Asks 'Proceed?'"
    },
    {
      "step": 8,
      "phase": "3.2_confirm_filters",
      "user_prompt": "Yes, proceed",
      "user_prompt_variants": ["Go ahead", "Looks good, start"],
