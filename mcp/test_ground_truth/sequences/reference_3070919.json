{
  "campaign_id": 3070919,
  "campaign_name": "Petr ES Australia",
  "structure": {
    "email_1": {
      "intent": "Hook + value prop + geo case study with specific numbers",
      "subject_pattern": "{{first_name}} - {action question}?",
      "body_elements": [
        "Direct value statement with specific metric (fees under 1%)",
        "Multiple payment methods listed",
        "{{city}} geo-specific case study with exact numbers ($4,000/month, 50 contractors, 8 countries)",
        "CTA: question, not demand",
        "Sender signature with title + company + social proof (5,000+ teams)"
      ],
      "word_count": "~80"
    },
    "email_2": {
      "intent": "Competitor comparison + bullet benefits",
      "subject": "(empty — reply thread)",
      "body_elements": [
        "Competitor names (Upwork, Deel)",
        "3-4 bullet benefits with dashes",
        "Each bullet: concrete benefit, not vague",
        "CTA: demo call this week"
      ],
      "word_count": "~70"
    },
    "email_3": {
      "intent": "Transparent pricing + social proof",
      "subject": "(empty — reply thread)",
      "body_elements": [
        "Exact pricing (3% or flat $39)",
        "Volume discount offer (50+ contractors)",
        "Feature highlight (mass payouts via Excel)",
        "CTA: 2-minute walkthrough video"
      ],
      "word_count": "~50"
    },
    "email_4": {
      "intent": "Ultra-short channel switch",
      "subject": "(empty — reply thread)",
      "body_elements": [
        "Channel switch (LinkedIn/Telegram)",
        "Competitor comparison offer",
        "Casual sign-off (Sent from my iPhone)"
      ],
      "word_count": "~25"
    }
  },
  "quality_markers": {
    "personalization_tags": ["{{first_name}}", "{{city}}"],
    "specific_numbers": ["1%", "$4,000/month", "50 contractors", "8 countries", "5,000+", "10-20%", "3%", "$39"],
    "competitors_named": ["Upwork", "Deel"],
    "no_spam_triggers": true,
    "varied_closings": true,
    "html_formatted": true,
    "reply_thread_subjects": true
  }
}
