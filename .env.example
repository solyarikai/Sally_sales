# ============================================================
# LeadGen Automation — Environment Variables
# ============================================================
# Copy to .env and fill in real values.
# Keys marked [REQUIRED] will trigger a startup warning if missing.
# ============================================================

# ── Database ────────────────────────────────────────────────
POSTGRES_USER=leadgen
POSTGRES_PASSWORD=leadgen_secret
POSTGRES_DB=leadgen
# docker-compose overrides this to use internal hostname
DATABASE_URL=postgresql+asyncpg://leadgen:leadgen_secret@postgres:5432/leadgen

# ── Redis ───────────────────────────────────────────────────
REDIS_URL=redis://redis:6379

# ── [REQUIRED] OpenAI — GPT scoring, contact extraction ────
OPENAI_API_KEY=sk-...

# ── [REQUIRED] Apollo — people enrichment by domain ─────────
APOLLO_API_KEY=...

# ── [REQUIRED] FindyMail — email verification + finding ─────
FINDYMAIL_API_KEY=...

# ── [REQUIRED] SmartLead — campaign push ────────────────────
SMARTLEAD_API_KEY=...

# ── Google Sheets / Drive ───────────────────────────────────
# Path to service account JSON (mounted in docker-compose)
GOOGLE_APPLICATION_CREDENTIALS=/app/google-credentials.json
GOOGLE_IMPERSONATE_EMAIL=services@getsally.io
SHARED_DRIVE_ID=0AEvTjlJFlWnZUk9PVA

# ── Yandex Search API ──────────────────────────────────────
YANDEX_SEARCH_API_KEY=...
YANDEX_SEARCH_FOLDER_ID=...

# ── Crona (JS-rendered website scraping) ────────────────────
CRONA_EMAIL=...
CRONA_PASSWORD=...

# ── Apify Proxy (Google SERP scraping) ──────────────────────
APIFY_PROXY_PASSWORD=...

# ── GetSales Integration ───────────────────────────────────
GETSALES_API_KEY=...

# ── Optional integrations ──────────────────────────────────
# GEMINI_API_KEY=...          # Google Gemini for complex reasoning
# INSTANTLY_API_KEY=...       # Instantly email campaigns
# CLAY_API_KEY=...            # Clay enrichment webhooks
# TELEGRAM_BOT_TOKEN=...     # Telegram notifications
# SLACK_BOT_TOKEN=...        # Slack notifications
