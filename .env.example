# ============================================================
# LeadGen Automation — Environment Variables
# ============================================================
# Copy to .env and fill in real values.
# Keys marked [REQUIRED] will trigger a startup warning if missing.
# ============================================================

# ── Database ────────────────────────────────────────────────
POSTGRES_USER=leadgen
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=leadgen
DATABASE_URL=postgresql+asyncpg://leadgen:CHANGE_ME@leadgen-postgres:5432/leadgen

# ── Redis ───────────────────────────────────────────────────
REDIS_URL=redis://leadgen-redis:6379/0

# ── [REQUIRED] OpenAI — GPT scoring, contact extraction ────
OPENAI_API_KEY=sk-...

# ── [REQUIRED] Apollo — people enrichment by domain ─────────
APOLLO_API_KEY=...

# ── [REQUIRED] FindyMail — email verification + finding ─────
FINDYMAIL_API_KEY=...

# ── [REQUIRED] SmartLead — campaign push ────────────────────
SMARTLEAD_API_KEY=...

# ── Google Sheets / Drive ───────────────────────────────────
GOOGLE_APPLICATION_CREDENTIALS=/app/google-credentials.json
SHARED_DRIVE_ID=...

# ── Yandex Search API ──────────────────────────────────────
YANDEX_SEARCH_API_KEY=...
YANDEX_SEARCH_FOLDER_ID=...

# ── Crona (JS-rendered website scraping) ────────────────────
CRONA_EMAIL=...
CRONA_PASSWORD=...

# ── Apify Proxy (Google SERP scraping) ──────────────────────
APIFY_PROXY_PASSWORD=...

# ── GetSales Integration ───────────────────────────────────
GETSALES_API_KEY=...

# ── Telegram Bot ────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=...
TELEGRAM_CHAT_ID=...

# ── Webhooks ────────────────────────────────────────────────
# Public URL where external systems (SmartLead, GetSales) send webhooks.
WEBHOOK_BASE_URL=http://YOUR_SERVER_IP:8000
# Optional: shared secret for webhook authentication.
# When set, webhook URLs include ?token=<secret> and incoming requests
# without a valid token are rejected with 403.
# WEBHOOK_SECRET=...

# ── Testing ─────────────────────────────────────────────────
# TEST_RECIPIENT_EMAIL=test@example.com

# ── Slack ───────────────────────────────────────────────────
# SLACK_BOT_TOKEN=xoxb-...
# SLACK_DEFAULT_CHANNEL=C09REGUQWTG

# ── Optional integrations ──────────────────────────────────
# GEMINI_API_KEY=...          # Google Gemini for complex reasoning
# INSTANTLY_API_KEY=...       # Instantly email campaigns
# CLAY_API_KEY=...            # Clay enrichment webhooks
